# .endday.env - endday skill configuration

# Diary and project progress files
DIARY_DIR=文档/70_工作日记
MEMORY_FILE=MEMORY.md

# Paths that should be staged by the repository-local endday workflow
STAGE_PATTERNS=.claude/CLAUDE.md,README.md,phase4_acceptance.sh,plans,文档/配置指南.md,文档/20_架构与实现,文档/30_测试与执行,文档/40_审查与诊断,文档/60_规划草案,文档/70_工作日记,scripts,heuristics,edge_uav,tests,最后实验/失败率

# Security checks
CHECK_SENSITIVE=true
AUTO_COMMIT=true

# Project CLAUDE.md maintenance
UPDATE_PROJECT_CLAUDE=true
PROJECT_CLAUDE_FILE=.claude/CLAUDE.md
PROJECT_ROOT=.

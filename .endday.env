# .endday.env - endday skill 配置文件

# ============================================================================
# 日记和进度文件配置
# ============================================================================

# 日记存储目录（默认：日记/）
DIARY_DIR=文档/70_工作日记

# MEMORY 文件路径（默认：MEMORY.md）
MEMORY_FILE=MEMORY.md

# 提交范围（逗号分隔，默认：MEMORY.md,日记/,src/,config/,tests/）
# 包含项目级 CLAUDE.md
STAGE_PATTERNS=CLAUDE.md,README.md,PHASE4_DIAGNOSTIC_GUIDE.md,phase4_acceptance.sh,plans,文档/20_架构与实现,文档/30_测试与执行,文档/40_审查与诊断,文档/70_工作日记,heuristics,edge_uav,tests,analyze_results.py

# ============================================================================
# 安全性配置
# ============================================================================

# 敏感文件检查（默认启用）
CHECK_SENSITIVE=true

# 是否自动提交（默认启用）
AUTO_COMMIT=true

# ============================================================================
# 项目级 CLAUDE.md 维护配置（新增）
# ============================================================================

# 是否自动维护项目级 CLAUDE.md（新功能）
UPDATE_PROJECT_CLAUDE=true

# 项目级 CLAUDE.md 文件路径
PROJECT_CLAUDE_FILE=CLAUDE.md

# 项目根目录（相对当前工作目录）
PROJECT_ROOT=.
